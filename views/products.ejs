<%- include('partials/header') %>

  <section class="products-layout">
    <div class="container products-layout-inner">
      <aside class="products-sidebar">
        <div class="sidebar-notebook">
          <div class="sidebar-notebook-header">
            <h3>Categories</h3>
          </div>
          <nav class="sidebar-nav">
            <a href="#" class="sidebar-nav-item active" data-filter="all">
              <span class="sidebar-nav-icon"><i class="fas fa-layer-group"></i></span>
              <span>All Products</span>
            </a>
            <a href="#" class="sidebar-nav-item" data-filter="fragrances">
              <span class="sidebar-nav-icon"><i class="fas fa-spray-can"></i></span>
              <span>Fragrances</span>
            </a>
            <a href="#" class="sidebar-nav-item" data-filter="cleaners">
              <span class="sidebar-nav-icon"><i class="fas fa-pump-soap"></i></span>
              <span>Cleaners</span>
            </a>
          </nav>
          <div class="sidebar-notebook-footer"></div>
        </div>
        <div class="sidebar-action">
          <a href="#" class="sidebar-cta-btn" id="ctaBtn">
            <span class="cta-btn-content">
              <span>Click for Latest Updates</span>
              <i class="fas fa-arrow-right"></i>
            </span>
          </a>
        </div>
      </aside>
      <main class="products-main">
        <div class="products-catalog-header">
          <div class="products-catalog-explore">
            <span class="explore-text">Explore our products</span>

          </div>
        </div>
        <div id="productsCatalog" class="products-catalog-grid"></div>
      </main>
    </div>
  </section>

  <div class="pkg-popup-overlay" id="pkgPopupOverlay">
    <div class="pkg-popup" id="pkgPopup">
      <button class="pkg-popup-close" id="pkgPopupClose" aria-label="Close">&times;</button>
      <div class="pkg-popup-icon"><i class="fas fa-box-open"></i></div>
      <span class="pkg-popup-title">See What's New </span>

      <ul class="pkg-popup-list">
        <li>Cleaning products are available in <strong>5-litre</strong> and <strong>500-ml</strong> packages.</li>
        <li>Air fresheners are available in <strong>5-litre</strong> and <strong>500-ml</strong> packages.</li>
        <li>Toilet bowl cleaners are available in <strong>5-litre</strong> and <strong>500-ml</strong> packages.</li>
      </ul>
    </div>
  </div>

  <%- include('partials/footer') %>