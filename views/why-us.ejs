<%- include('partials/header') %>

  <section class="section page-hero">
    <div class="container" style="text-align:center">
      <span class="section-tag">Why Choose Royal Klense</span>
      <h1 class="section-title">Partner with a Global-Standard Manufacturer</h1>
      <p class="section-desc" style="max-width:650px;margin:0 auto">We combine quality, innovation, and service to deliver exceptional value.</p>
    </div>
  </section>

  <section class="section why-us" style="padding-top:0">
    <div class="container">
      <div class="features-grid" id="featuresGrid"></div>
    </div>
  </section>

  <section class="manufacturing" style="padding:80px 0">
    <div class="container">
      <div class="section-header reveal-3d" data-delay="0">
        <span class="section-tag">Manufacturing Excellence</span>
        <h2 class="section-title">State-of-the-Art Production Facilities</h2>
        <p class="section-desc">Our manufacturing processes adhere to international quality standards at every stage.</p>
      </div>
      <div class="manufacturing-grid">
        <div class="manufacturing-card reveal" data-delay="0">
          <div class="manufacturing-icon"><i class="fas fa-industry"></i></div>
          <h3>Modern Facility</h3>
          <p>Spread across 50,000 sq. ft. with automated production lines and advanced quality control systems.</p>
        </div>
        <div class="manufacturing-card reveal" data-delay="100">
          <div class="manufacturing-icon"><i class="fas fa-microscope"></i></div>
          <h3>Quality Control</h3>
          <p>Every batch undergoes rigorous testing in our in-house laboratory for consistency and safety.</p>
        </div>
        <div class="manufacturing-card reveal" data-delay="200">
          <div class="manufacturing-icon"><i class="fas fa-dna"></i></div>
          <h3>Research & Development</h3>
          <p>Our R&D team develops innovative, eco-friendly formulations that exceed industry standards.</p>
        </div>
        <div class="manufacturing-card reveal" data-delay="300">
          <div class="manufacturing-icon"><i class="fas fa-box"></i></div>
          <h3>Premium Packaging</h3>
          <p>We use high-quality, sustainable packaging that preserves product integrity and reduces environmental impact.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section certifications">
    <div class="container">
      <div class="section-header reveal-3d" data-delay="0">
        <span class="section-tag">Certifications & Quality</span>
        <h2 class="section-title">Our Commitment to Excellence</h2>
        <p class="section-desc">We are certified by leading international standards organizations.</p>
      </div>
      <div class="cert-grid">
        <div class="cert-card reveal" data-delay="0">
          <div class="cert-icon"><i class="fas fa-medal"></i></div>
          <h3>ISO 9001:2015</h3>
          <p>Quality Management System certified for consistent product quality and customer satisfaction.</p>
        </div>
        <div class="cert-card reveal" data-delay="100">
          <div class="cert-icon"><i class="fas fa-shield-alt"></i></div>
          <h3>ISO 14001:2015</h3>
          <p>Environmental Management System ensuring our operations meet global environmental standards.</p>
        </div>
        <div class="cert-card reveal" data-delay="200">
          <div class="cert-icon"><i class="fas fa-flask"></i></div>
          <h3>GMP Certified</h3>
          <p>Good Manufacturing Practices certified facility following stringent production guidelines.</p>
        </div>
        <div class="cert-card reveal" data-delay="300">
          <div class="cert-icon"><i class="fas fa-check-circle"></i></div>
          <h3>MSME Registered</h3>
          <p>Registered with Ministry of Micro, Small & Medium Enterprises, Government of India.</p>
        </div>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
