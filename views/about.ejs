<%- include('partials/header', { title: 'About Us', currentPage: 'about' }) %>

  <section class="section page-hero">
    <div class="container" style="text-align:center">
      <span class="section-tag">About Us</span>
      <h1 class="section-title" style="font-size:3.5rem">India's Trusted Manufacturer of Premium Cleaning Solutions</h1>
      <p class="section-desc" style="max-width:600px;margin:0 auto">Committed to quality, innovation, and customer satisfaction since 2024.</p>
    </div>
  </section>

  <section class="section about" style="padding-top:0">
    <div class="container">
      <div class="about-grid">
        <div class="about-image reveal" data-delay="0">
          <div class="about-image-frame">
            <div class="about-image-placeholder">
              <img src="/images/WhatsApp%20Image%202026-06-23%20at%206.15.56%20PM.jpeg" alt="Royal Klense Manufacturing Facility">
            </div>
          </div>
          <div class="about-badge">3+ Years of Expertise</div>
        </div>
        <div class="about-content reveal" data-delay="200">
          <span class="section-tag">Who We Are</span>
          <h2 class="section-title">Our Story</h2>
          <p class="about-text">Royal Klense is a premier manufacturer of high-quality cleaning chemicals and hygiene solutions. With state-of-the-art manufacturing facilities and a commitment to excellence, we serve thousands of businesses across India.</p>
          <p class="about-text">Our ISO-certified production processes ensure consistent quality, while our R&D team continuously innovates to meet evolving industry standards. We take pride in being the preferred partner for hotels, hospitals, industries, and institutions.</p>
          <p class="about-text">Founded with a vision to provide world-class hygiene solutions, Royal Klense has grown rapidly to become a trusted name in the cleaning industry. Our team of experienced chemists and industry professionals work tirelessly to develop products that meet the highest standards of quality and effectiveness.</p>
          <div class="about-features">
            <div class="about-feature">
              <i class="fas fa-certificate"></i>
              <span>ISO Certified</span>
            </div>
            <div class="about-feature">
              <i class="fas fa-flask"></i>
              <span>R&D Driven</span>
            </div>
            <div class="about-feature">
              <i class="fas fa-truck"></i>
              <span>Pan India Supply</span>
            </div>
            <div class="about-feature">
              <i class="fas fa-leaf"></i>
              <span>Eco-Friendly</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="credentials">
    <div class="container">
      <div class="section-header reveal" data-delay="0" style="margin-bottom:40px">
        <span class="section-tag">Certifications</span>
        <h2 class="section-title">Our Credentials</h2>
      </div>
      <div class="credentials-grid">
        <span class="cred-logo">ISO 9001:2015</span>
        <span class="cred-logo">ISO 14001:2015</span>
        <span class="cred-logo">GMP Certified</span>
        <span class="cred-logo">MSME Registered</span>
        <span class="cred-logo">Make in India</span>
      </div>
    </div>
  </section>

  <section class="section why-us">
    <div class="container">
      <div class="section-header light reveal" data-delay="0">
        <span class="section-tag">Why Choose Us</span>
        <h2 class="section-title">Partner with a Global-Standard Manufacturer</h2>
        <p class="section-desc">We combine quality, innovation, and service to deliver exceptional value.</p>
      </div>
      <div class="features-grid" id="featuresGrid"></div>
    </div>
  </section>

<%- include('partials/footer') %>
