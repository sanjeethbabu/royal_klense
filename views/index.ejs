<%- include('partials/header') %>

  <section id="home" class="hero hero-video-section">
    <div class="hero-video-wrap">
      <video class="hero-video" muted playsinline preload="auto" id="heroVideo">
        <source src="/video/surface-clean.mp4" type="video/mp4">
      </video>
    </div>
    <div class="hero-geometric hero-depth-layer"></div>
    <div class="hero-geometric hero-geometric-2 hero-depth-layer"></div>
    <div class="container hero-container">
      <div class="hero-content">
        <h1 class="hero-title hero-title-gold">Pure Royal Care</h1>
        <p class="hero-subtitle">Delivering high-performance cleaning chemicals, housekeeping products, and
          hygiene solutions trusted by hotels, hospitals, industries, and institutions.</p>

      </div>

    </div>
    <div class="hero-scroll" id="heroScroll">
      <span>Scroll</span>
      <i class="fas fa-chevron-down"></i>
    </div>
  </section>

  <section id="about" class="section about">
    <div class="container">
      <div class="about-grid">
        <div class="about-image reveal" data-delay="0">
          <div class="about-image-frame img-depth">
            <div class="about-image-placeholder">
              <img src="/images/all_p.jpeg"
                alt="Royal Klense Manufacturing Facility" class="about-3d-img">
            </div>
          </div>
          <div class="about-badge tilt-3d-content">5+ Years of Expertise</div>
        </div>
        <div class="about-content reveal" data-delay="150">
          <span class="section-tag">Who We Are</span>
          <h2 class="section-title">India's Upcoming Trusted Manufacturer of premium Cleaning Solutions</h2>
          <p class="about-text">Royal Klense is a premier manufacturer of high-quality cleaning chemicals and hygiene
            solutions. With state-of-the-art manufacturing facilities and a commitment to excellence, we serve thousands
            of businesses across India.</p>
          <p class="about-text">Our ISO-certified production processes ensure consistent quality, while our R&D team
            continuously innovates to meet evolving industry standards. We take pride in being the preferred partner for
            hotels, hospitals, industries, and institutions.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="credentials">
    <div class="container">
      <div class="section-header reveal" data-delay="0" style="margin-bottom:40px">
        <span class="section-tag">Certifications</span>
        <h2 class="section-title">Our Credentials</h2>
      </div>
      <div class="credentials-grid">
        <span class="cred-logo">ISO 9001:2015</span>
        <span class="cred-logo">ISO 14001:2015</span>
        <span class="cred-logo">GMP Certified</span>
        <span class="cred-logo">MSME Registered</span>
        <span class="cred-logo">Make in India</span>
      </div>
    </div>
  </section>

  <section id="industries" class="section industries">
    <div class="container">
      <span class="section-tag">Our Business Associates</span>
      <div class="clients-wall">
        <div class="clients-track" id="clientsTrack">
          <div class="client-logo"><span>Hotel Grand</span></div>
          <div class="client-logo"><span>City Hospital</span></div>
          <div class="client-logo"><span>Elite Facilities</span></div>
          <div class="client-logo"><span>Prestige Hotels</span></div>
          <div class="client-logo"><span>MediCare Group</span></div>
          <div class="client-logo"><span>Royal Hospitality</span></div>
          <div class="client-logo"><span>CleanCorp India</span></div>
          <div class="client-logo"><span>Summit Industries</span></div>
          <div class="client-logo"><span>Hotel Grand</span></div>
          <div class="client-logo"><span>City Hospital</span></div>
          <div class="client-logo"><span>Elite Facilities</span></div>
          <div class="client-logo"><span>Prestige Hotels</span></div>
        </div>
      </div>
      <div class="industries-grid" id="industriesGridTop" style="margin-top:16px"></div>
    </div>
  </section>

  <section class="section industries" style="padding-top:0">
    <div class="container">
      <div class="industries-grid" id="industriesGridBottom"></div>
    </div>
  </section>

  <section class="section testimonials">
    <div class="container">
      <div class="section-header reveal-3d" data-delay="0">
        <span class="section-tag">Testimonials</span>
        <h2 class="section-title">What Our Clients Say</h2>
        <p class="section-desc">Trusted by leading businesses across India.</p>
      </div>
      <div class="testimonials-carousel" id="testimonialsCarousel"></div>
      <div class="testimonial-controls">
        <button class="testimonial-btn prev-btn" id="prevTestimonial" aria-label="Previous testimonial"><i
            class="fas fa-arrow-left"></i></button>
        <div class="testimonial-dots" id="testimonialDots"></div>
        <button class="testimonial-btn next-btn" id="nextTestimonial" aria-label="Next testimonial"><i
            class="fas fa-arrow-right"></i></button>
      </div>
    </div>
  </section>

  <section class="section video-testimonials">
    <div class="container">
      <div class="section-header reveal-3d" data-delay="0">
        <span class="section-tag">They Speak Well of Us</span>
        <h2 class="section-title">Video Testimonials</h2>
        <p class="section-desc">Hear from our satisfied clients and partners.</p>
      </div>
      <div class="video-grid" id="videoGrid"></div>
    </div>
  </section>

  <section class="section cta">
    <div class="cta-overlay"></div>
    <div class="container cta-container">
      <h2 class="cta-title">Let's Build Cleaner, Safer Spaces Together</h2>
      <p class="cta-text">Partner with Royal Klense for premium cleaning solutions that elevate hygiene standards and
        build trust.</p>
      <div class="cta-actions">
        <a href="#" class="btn btn-primary btn-lg btn-3d" onclick="openQuoteModal();return false">Get a Quote <i
            class="fas fa-arrow-right"></i></a>
        <a href="#" class="btn btn-outline btn-lg btn-3d" onclick="openContactModal();return false">Contact Us</a>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>