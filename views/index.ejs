<%- include('partials/header', { title: 'Home', currentPage: 'home' }) %>

  <section id="home" class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-waves">
      <div class="wave wave-1"></div>
      <div class="wave wave-2"></div>
      <div class="wave wave-3"></div>
    </div>
    <div class="hero-geometric hero-depth-layer"></div>
    <div class="hero-geometric hero-geometric-2 hero-depth-layer"></div>
    <div class="container hero-container">
      <div class="hero-content hero-depth-layer">
        <span class="hero-badge hero-depth-1">Est. 2023</span>
        <h1 class="hero-title hero-depth-3">Premium Hygiene & Cleaning Solutions for Modern Businesses</h1>
        <p class="hero-subtitle hero-depth-2">Delivering high-performance cleaning chemicals, housekeeping products, and hygiene solutions trusted by hotels, hospitals, industries, and institutions.</p>
        <div class="hero-actions hero-depth-1">
          <a href="/products" class="btn btn-primary btn-3d">Explore Products <i class="fas fa-arrow-right"></i></a>
          <a href="/contact" class="btn btn-outline btn-3d">Request Quote</a>
        </div>
      </div>
      <div class="hero-stats hero-depth-layer">
        <div class="hero-stat stat-tilt">
          <span class="hero-stat-num tilt-3d-content" data-count="300">0</span>
          <span class="hero-stat-label tilt-3d-content-close">Products</span>
        </div>
        <div class="hero-stat stat-tilt">
          <span class="hero-stat-num tilt-3d-content" data-count="1000">0</span>
          <span class="hero-stat-label tilt-3d-content-close">Customers</span>
        </div>
        <div class="hero-stat stat-tilt">
          <span class="hero-stat-num tilt-3d-content" data-count="12">0</span>
          <span class="hero-stat-label tilt-3d-content-close">Categories</span>
        </div>
      </div>
    </div>
    <div class="hero-scroll hero-depth-1">
      <span>Scroll</span>
      <i class="fas fa-chevron-down"></i>
    </div>
  </section>

  <section id="about" class="section about">
    <div class="container">
      <div class="about-grid">
        <div class="about-image reveal-3d-left" data-delay="0">
          <div class="about-image-frame img-depth">
            <div class="about-image-placeholder">
              <img src="/images/WhatsApp%20Image%202026-06-23%20at%206.15.56%20PM.jpeg" alt="Royal Klense Manufacturing Facility">
            </div>
          </div>
          <div class="about-badge tilt-3d-content">3+ Years of Expertise</div>
        </div>
        <div class="about-content reveal-3d-right" data-delay="200">
          <span class="section-tag">Who We Are</span>
          <h2 class="section-title">India's Trusted Manufacturer of Premium Cleaning Solutions</h2>
          <p class="about-text">Royal Klense is a premier manufacturer of high-quality cleaning chemicals and hygiene solutions. With state-of-the-art manufacturing facilities and a commitment to excellence, we serve thousands of businesses across India.</p>
          <p class="about-text">Our ISO-certified production processes ensure consistent quality, while our R&D team continuously innovates to meet evolving industry standards. We take pride in being the preferred partner for hotels, hospitals, industries, and institutions.</p>
          <div class="about-features">
            <div class="about-feature tilt-3d-content-close">
              <i class="fas fa-certificate"></i>
              <span>ISO Certified</span>
            </div>
            <div class="about-feature tilt-3d-content-close">
              <i class="fas fa-flask"></i>
              <span>R&D Driven</span>
            </div>
            <div class="about-feature tilt-3d-content-close">
              <i class="fas fa-truck"></i>
              <span>Pan India Supply</span>
            </div>
            <div class="about-feature tilt-3d-content-close">
              <i class="fas fa-leaf"></i>
              <span>Eco-Friendly</span>
            </div>
          </div>
          <a href="/about" class="btn btn-primary btn-3d" style="margin-top:24px">Learn More About Us <i class="fas fa-arrow-right"></i></a>
        </div>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
