<%- include('partials/header', { title: 'Industries', currentPage: 'industries' }) %>

<style>
  .clients .section-tag::after { margin: 4px auto 0; }
</style>

  <section class="section page-hero">
    <div class="container" style="text-align:center">
      <span class="section-tag">Industries We Serve</span>
      <h1 class="section-title" style="font-size:3.5rem">Trusted Across Sectors</h1>
      <p class="section-desc" style="max-width:600px;margin:0 auto">Our solutions are tailored to meet the unique requirements of various industries.</p>
    </div>
  </section>

  <section class="section industries" style="padding-top:0;padding-bottom:0">
    <div class="container">
      <div class="industries-grid" id="industriesGridTop"></div>
    </div>
  </section>

  <section class="section clients" style="padding-top:0;padding-bottom:0">
    <div class="container">
      <div class="section-header" style="margin-bottom:0">
        <span class="section-tag" style="margin-bottom:0;font-weight:900">Our Partners</span>
      </div>
      <div class="clients-wall">
        <div class="clients-track" id="clientsTrack">
          <div class="client-logo"><span>Hotel Grand</span></div>
          <div class="client-logo"><span>City Hospital</span></div>
          <div class="client-logo"><span>Elite Facilities</span></div>
          <div class="client-logo"><span>Prestige Hotels</span></div>
          <div class="client-logo"><span>MediCare Group</span></div>
          <div class="client-logo"><span>Royal Hospitality</span></div>
          <div class="client-logo"><span>CleanCorp India</span></div>
          <div class="client-logo"><span>Summit Industries</span></div>
          <div class="client-logo"><span>Hotel Grand</span></div>
          <div class="client-logo"><span>City Hospital</span></div>
          <div class="client-logo"><span>Elite Facilities</span></div>
          <div class="client-logo"><span>Prestige Hotels</span></div>
        </div>
      </div>
    </div>
  </section>

  <section class="section industries" style="padding-top:0">
    <div class="container">
      <div class="industries-grid" id="industriesGridBottom"></div>
    </div>
  </section>

  <section class="section video-testimonials">
    <div class="container">
      <div class="section-header reveal" data-delay="0">
        <span class="section-tag">They Speak Well of Us</span>
        <h2 class="section-title">Video Testimonials</h2>
        <p class="section-desc">Hear from our satisfied clients and partners.</p>
      </div>
      <div class="video-grid" id="videoGrid"></div>
    </div>
  </section>

  <section class="section testimonials">
    <div class="container">
      <div class="section-header reveal" data-delay="0">
        <span class="section-tag">Testimonials</span>
        <h2 class="section-title">What Our Clients Say</h2>
        <p class="section-desc">Trusted by leading businesses across India.</p>
      </div>
      <div class="testimonials-carousel" id="testimonialsCarousel"></div>
      <div class="testimonial-controls">
        <button class="testimonial-btn prev-btn" id="prevTestimonial"><i class="fas fa-arrow-left"></i></button>
        <div class="testimonial-dots" id="testimonialDots"></div>
        <button class="testimonial-btn next-btn" id="nextTestimonial"><i class="fas fa-arrow-right"></i></button>
      </div>
    </div>
  </section>

<%- include('partials/footer') %>
